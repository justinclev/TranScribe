# Generated by Transcribe - SOC2 Compliant Architecture

# ── ALB Security Group ───────────────────────────────────────────────────────

resource "aws_security_group" "myapp_alb" {
  name        = "myapp-alb-sg"
  description = "Internet-facing ALB: allow 80 and 443 inbound"
  vpc_id      = aws_vpc.myapp.id

  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "myapp-alb-sg"
  }
}

# ── ECS Security Group ────────────────────────────────────────────────────────

resource "aws_security_group" "myapp_ecs" {
  name        = "myapp-ecs-sg"
  description = "ECS tasks: allow inbound from ALB on ephemeral ports"
  vpc_id      = aws_vpc.myapp.id

  ingress {
    description     = "From ALB"
    from_port       = 1024
    to_port         = 65535
    protocol        = "tcp"
    security_groups = [aws_security_group.myapp_alb.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "myapp-ecs-sg"
  }
}

# ── RDS / Cache Security Group ────────────────────────────────────────────────
# One shared SG with an ingress rule per managed database engine port.

resource "aws_security_group" "myapp_db" {
  name        = "myapp-db-sg"
  description = "Database: allow inbound from ECS tasks only"
  vpc_id      = aws_vpc.myapp.id

  ingress {
    description     = "From ECS to db (postgres)"
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.myapp_ecs.id]
  }

  ingress {
    description     = "From ECS to redis (redis)"
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.myapp_ecs.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "myapp-db-sg"
  }
}
