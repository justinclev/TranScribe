# Generated by Transcribe - SOC2 Compliant Architecture
# ── Application Load Balancer ─────────────────────────────────────────────────

resource "aws_lb" "myapp" {
  name               = "${local.env}-alb"
  internal           = false
  load_balancer_type = "application"
  security_groups    = [aws_security_group.myapp_alb.id]
  subnets            = [
    aws_subnet.myapp_public_1.id,
    aws_subnet.myapp_public_2.id,
  ]

  enable_deletion_protection = true

  access_logs {
    bucket  = aws_s3_bucket.myapp_alb_logs.bucket
    prefix  = "alb"
    enabled = true
  }

  tags = {
    Name = "myapp-alb"
  }
}

# ── ALB Access Logs S3 Bucket ─────────────────────────────────────────────────

resource "aws_s3_bucket" "myapp_alb_logs" {
  bucket        = "${local.env}-myapp-alb-access-logs-${data.aws_caller_identity.current.account_id}"
  force_destroy = false

  tags = {
    Name = "${local.env}-myapp-alb-access-logs"
  }
}

resource "aws_s3_bucket_versioning" "myapp_alb_logs" {
  bucket = aws_s3_bucket.myapp_alb_logs.id

  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "myapp_alb_logs" {
  bucket = aws_s3_bucket.myapp_alb_logs.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm     = "aws:kms"
      kms_master_key_id = aws_kms_key.myapp.arn
    }
  }
}

resource "aws_s3_bucket_public_access_block" "myapp_alb_logs" {
  bucket                  = aws_s3_bucket.myapp_alb_logs.id
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# ── HTTP → HTTPS redirect listener ───────────────────────────────────────────

resource "aws_lb_listener" "myapp_http" {
  load_balancer_arn = aws_lb.myapp.arn
  port              = 80
  protocol          = "HTTP"

  default_action {
    type = "redirect"

    redirect {
      port        = "443"
      protocol    = "HTTPS"
      status_code = "HTTP_301"
    }
  }
}

# ── HTTPS listener ────────────────────────────────────────────────────────────

resource "aws_lb_listener" "myapp_https" {
  load_balancer_arn = aws_lb.myapp.arn
  port              = 443
  protocol          = "HTTPS"
  ssl_policy        = "ELBSecurityPolicy-TLS13-1-2-2021-06"
  certificate_arn   = aws_acm_certificate.myapp.arn

  default_action {
    type = "fixed-response"

    fixed_response {
      content_type = "text/plain"
      message_body = "Not Found"
      status_code  = "404"
    }
  }

  depends_on = [aws_acm_certificate_validation.myapp]
}

# ── ACM Certificate ───────────────────────────────────────────────────────────

resource "aws_acm_certificate" "myapp" {
  domain_name       = "myapp.com"
  validation_method = "DNS"

  lifecycle {
    create_before_destroy = true
  }

  tags = {
    Name = "${local.env}-myapp-cert"
  }
}

# ── Route 53 DNS Certificate Validation ──────────────────────────────────────

data "aws_route53_zone" "myapp" {
  name         = "myapp.com"
  private_zone = false
}

resource "aws_route53_record" "myapp_cert_validation" {
  for_each = {
    for dvo in aws_acm_certificate.myapp.domain_validation_options : dvo.domain_name => {
      name   = dvo.resource_record_name
      record = dvo.resource_record_value
      type   = dvo.resource_record_type
    }
  }

  allow_overwrite = true
  name            = each.value.name
  records         = [each.value.record]
  ttl             = 60
  type            = each.value.type
  zone_id         = data.aws_route53_zone.myapp.zone_id
}

resource "aws_acm_certificate_validation" "myapp" {
  certificate_arn         = aws_acm_certificate.myapp.arn
  validation_record_fqdns = [for record in aws_route53_record.myapp_cert_validation : record.fqdn]
}

# ── Target Group: api ──────────────────────────────────────────────

resource "aws_lb_target_group" "api" {
  name        = "${local.env}-api-tg"
  port        = 8080
  protocol    = "HTTP"
  vpc_id      = aws_vpc.myapp.id
  target_type = "ip"

  health_check {
    enabled             = true
    healthy_threshold   = 2
    unhealthy_threshold = 3
    interval            = 30
    path                = "/health"
    protocol            = "HTTP"
    timeout             = 5
    matcher             = "200-399"
  }

  tags = {
    Name = "myapp-api-tg"
  }
}

resource "aws_lb_listener_rule" "api" {
  listener_arn = aws_lb_listener.myapp_https.arn
  priority     = 100

  action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.api.arn
  }

  condition {
    path_pattern {
      values = ["/api/*", "/api"]
    }
  }
}

# ── Target Group: frontend ──────────────────────────────────────────────

resource "aws_lb_target_group" "frontend" {
  name        = "${local.env}-frontend-tg"
  port        = 3000
  protocol    = "HTTP"
  vpc_id      = aws_vpc.myapp.id
  target_type = "ip"

  health_check {
    enabled             = true
    healthy_threshold   = 2
    unhealthy_threshold = 3
    interval            = 30
    path                = "/"
    protocol            = "HTTP"
    timeout             = 5
    matcher             = "200-399"
  }

  tags = {
    Name = "myapp-frontend-tg"
  }
}

resource "aws_lb_listener_rule" "frontend" {
  listener_arn = aws_lb_listener.myapp_https.arn
  priority     = 999

  action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.frontend.arn
  }

  condition {
    path_pattern {
      values = ["/*"]
    }
  }
}

