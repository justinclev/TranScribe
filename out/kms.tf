# Generated by Transcribe - SOC2 Compliant Architecture

# ── Customer-Managed KMS Key ─────────────────────────────────────────────────
# Used for: ECS secrets, ECR images, CloudWatch logs, RDS, S3 ALB access logs.

resource "aws_kms_key" "myapp" {
  description             = "${local.env}-myapp — SOC2 encryption at rest"
  deletion_window_in_days = 30
  enable_key_rotation     = true
  multi_region            = false

  tags = {
    Name = "${local.env}-myapp-kms"
  }
}

resource "aws_kms_alias" "myapp" {
  name          = "alias/${local.env}-myapp"
  target_key_id = aws_kms_key.myapp.key_id
}
