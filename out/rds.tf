# Generated by Transcribe - SOC2 Compliant Architecture

# ── RDS Instance (postgres / db) ────────────────────────────

resource "aws_db_subnet_group" "myapp_db" {
  name       = "myapp-db-subnet-group"
  subnet_ids = [
    aws_subnet.myapp_private_1.id,
    aws_subnet.myapp_private_2.id,
  ]

  tags = {
    Name = "myapp-db-subnet-group"
  }
}

resource "aws_db_instance" "myapp_db" {
  identifier        = "myapp-db"
  engine            = "postgres"
  engine_version    = "16.1"
  instance_class    = "db.t3.medium"
  allocated_storage = 20
  storage_type      = "gp3"
  storage_encrypted = true
  kms_key_id        = aws_kms_key.myapp.arn

  db_name  = "myapp"
  username = "admin"
  password = aws_secretsmanager_secret_version.myapp_db_password.secret_string

  vpc_security_group_ids = [aws_security_group.myapp_db.id]
  db_subnet_group_name   = aws_db_subnet_group.myapp_db.name
  publicly_accessible    = false

  backup_retention_period = 7
  deletion_protection     = true
  skip_final_snapshot     = false
  final_snapshot_identifier = "myapp-db-final"

  enabled_cloudwatch_logs_exports = ["postgresql"]

  tags = {
    Name = "myapp-db"
  }
}

resource "aws_secretsmanager_secret" "myapp_db_password" {
  name                    = "myapp/db/password"
  kms_key_id              = aws_kms_key.myapp.arn
  recovery_window_in_days = 7

  tags = {
    Name    = "myapp-db-password"
    Service = "db"
  }
}

resource "aws_secretsmanager_secret_version" "myapp_db_password" {
  secret_id     = aws_secretsmanager_secret.myapp_db_password.id
  secret_string = random_password.myapp_db.result

  lifecycle {
    ignore_changes = [secret_string]
  }
}

resource "random_password" "myapp_db" {
  length           = 32
  special          = true
  override_special = "!#$%&*()-_=+[]{}<>:?"
}

# ── ElastiCache for Redis (redis) ──────────────────────────────────

resource "aws_elasticache_subnet_group" "myapp_redis" {
  name       = "myapp-redis-cache-subnet-group"
  subnet_ids = [
    aws_subnet.myapp_private_1.id,
    aws_subnet.myapp_private_2.id,
  ]
  tags = { Name = "myapp-redis-cache-subnet-group" }
}

resource "aws_elasticache_replication_group" "myapp_redis" {
  replication_group_id = "myapp-redis"
  description          = "myapp Redis replication group for redis"
  engine               = "redis"
  engine_version       = "7.0"
  node_type            = "cache.t3.micro"
  num_cache_clusters   = 2
  automatic_failover_enabled = true
  at_rest_encryption_enabled = true
  kms_key_id                 = aws_kms_key.myapp.arn
  transit_encryption_enabled = true
  subnet_group_name          = aws_elasticache_subnet_group.myapp_redis.name
  security_group_ids         = [aws_security_group.myapp_db.id]

  tags = { Name = "myapp-redis-redis" }
}
